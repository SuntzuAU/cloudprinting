---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../site.config.json';
const c = site.colours;
const extraSchema = [{
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Enterprise Cloud Print Management -- Printix",
  "description": "Hybrid cloud print management for multi-site enterprise organisations. Eliminate print servers at scale.",
  "url": site.siteUrl + "/enterprise",
  "isPartOf": { "@type": "WebSite", "name": site.siteName, "url": site.siteUrl }
}];
---
<BaseLayout title="Enterprise Cloud Print Management -- Printix" description="Hybrid cloud print management for multi-site enterprise organisations. Eliminate print servers, unify infrastructure, and reduce IT overhead at scale." extraSchema={extraSchema}>
  <section class="section-pad">
    <div class="container usecase-hero">
      <p class="eyebrow">ENTERPRISE</p>
      <h1 style="font-size:clamp(28px,4vw,42px);font-weight:800;margin-bottom:16px">Cloud print management at scale</h1>
      <p class="muted" style="font-size:16px;line-height:1.7;margin-bottom:24px;max-width:600px">Replace print servers across every site with a single cloud-managed platform. Printix handles driver management, queue automation, secure release, and reporting for organisations from hundreds to thousands of users.</p>
      <div style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:12px"><a href={site.hero.ctaPrimaryUrl} class="btn-primary">Start free trial</a><a href="/contact" class="btn-secondary">Request a quote</a></div>
      <p class="muted" style="font-size:13px">Free 30-day trial. All features included.</p>
    </div>
  </section>
  <section class="section-pad section-neutral">
    <div class="container" style="max-width:800px">
      <h2 class="text-center" style="margin-bottom:40px">Why enterprise organisations choose Printix</h2>
      <div class="benefit-grid">
        <div class="benefit"><h3>Eliminate print servers entirely</h3><p class="muted">Remove traditional print servers from every site. Printix manages everything from the cloud while print processing stays on your local network. No servers to maintain, patch, or back up.</p></div>
        <div class="benefit"><h3>Hybrid cloud architecture</h3><p class="muted">Add cloud-managed home and remote printing alongside existing on-premise infrastructure. Bridge legacy systems with modern cloud control without a full rip-and-replace.</p></div>
        <div class="benefit"><h3>Automated driver and queue management</h3><p class="muted">Cloud driver store with automated queue and driver installation. Reduce helpdesk tickets, simplify onboarding, and standardise configurations across all sites.</p></div>
        <div class="benefit"><h3>Cross-platform support</h3><p class="muted">Print from Windows, Mac, Chromebook, iOS, and Android. Support every device in your organisation without platform-specific infrastructure.</p></div>
        <div class="benefit"><h3>SSO and endpoint management</h3><p class="muted">Integrate with Microsoft Entra ID, Google Workspace, Okta, or OneLogin. Deploy via Microsoft Endpoint Manager for zero-touch rollout.</p></div>
        <div class="benefit"><h3>Volume pricing from A$2.46/user/month</h3><p class="muted">All features included at every tier. No per-printer fees. No per-page fees. Volume discounts as your organisation grows. Multi-year terms available.</p></div>
      </div>
    </div>
  </section>
  <section class="section-pad">
    <div class="container text-center" style="max-width:600px">
      <h2 style="margin-bottom:12px">Start with a free trial</h2>
      <p class="muted" style="margin-bottom:24px">30 days, all features, no credit card required.</p>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap"><a href="/pricing" class="btn-secondary">View pricing</a><a href={site.hero.ctaPrimaryUrl} class="btn-primary">Start free trial</a></div>
    </div>
  </section>
  <style is:inline>
    .eyebrow{font-size:12px;font-weight:600;color:var(--brand);letter-spacing:0.06em;text-transform:uppercase;margin-bottom:12px}
    .usecase-hero{max-width:700px}
    .benefit-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px}
    .benefit{padding:24px;border:1px solid var(--border);border-radius:14px;background:#fff}
    .benefit h3{font-size:16px;font-weight:600;margin-bottom:8px}
    .benefit .muted{font-size:14px;line-height:1.7}
    @media(max-width:768px){.benefit-grid{grid-template-columns:1fr}}
  </style>
</BaseLayout>
