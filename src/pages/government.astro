---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../site.config.json';
const c = site.colours;
const extraSchema = [{
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Cloud Print Management for Government",
  "description": "Secure cloud printing for Australian government departments. Audit trails, compliance controls, and simplified multi-site operations.",
  "url": site.siteUrl + "/government",
  "isPartOf": { "@type": "WebSite", "name": site.siteName, "url": site.siteUrl }
}];
---
<BaseLayout title="Cloud Print Management for Government -- Printix" description="Secure cloud printing for Australian government departments. Audit trails, compliance controls, multi-site management, and shared device support." extraSchema={extraSchema}>
  <section class="section-pad">
    <div class="container usecase-hero">
      <p class="eyebrow">GOVERNMENT</p>
      <h1 style="font-size:clamp(28px,4vw,42px);font-weight:800;margin-bottom:16px">Secure cloud printing for government</h1>
      <p class="muted" style="font-size:16px;line-height:1.7;margin-bottom:24px;max-width:600px">Eliminate print servers across departments and sites. Printix delivers centralised management, audit trails, and compliance-ready print infrastructure without the overhead of on-premise servers.</p>
      <div style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:12px"><a href={site.hero.ctaPrimaryUrl} class="btn-primary">Start free trial</a><a href="/contact" class="btn-secondary">Request a quote</a></div>
      <p class="muted" style="font-size:13px">Free 30-day trial. All features included.</p>
    </div>
  </section>
  <section class="section-pad section-neutral">
    <div class="container" style="max-width:800px">
      <h2 class="text-center" style="margin-bottom:40px">Built for government environments</h2>
      <div class="benefit-grid">
        <div class="benefit"><h3>Multi-site centralised management</h3><p class="muted">Manage printers, queues, and policies across every office, floor, and region from a single cloud dashboard. No site visits required for configuration changes.</p></div>
        <div class="benefit"><h3>Audit trails and reporting</h3><p class="muted">Centralised print reporting with user-level audit trails. Track print volumes, identify waste, and produce compliance reports for procurement and oversight.</p></div>
        <div class="benefit"><h3>Secure print release</h3><p class="muted">Documents held until the user releases them at the device via app, QR code, NFC tap, or ID badge. No uncollected documents left on shared printers.</p></div>
        <div class="benefit"><h3>Shared device support</h3><p class="muted">Printix works on shared workstations and hot-desking environments. Users authenticate via SSO and print to their nearest device regardless of which machine they are using.</p></div>
        <div class="benefit"><h3>Identity integration</h3><p class="muted">Authenticate with Microsoft Entra ID, Google Workspace, or Okta. Deploy via Microsoft Endpoint Manager. Fits existing identity and security frameworks.</p></div>
        <div class="benefit"><h3>Print data stays local</h3><p class="muted">Print jobs are processed on the local network, never sent through the cloud. Configuration and policy management happens in the cloud; document data does not leave your network.</p></div>
      </div>
    </div>
  </section>
  <section class="section-pad">
    <div class="container text-center" style="max-width:600px">
      <h2 style="margin-bottom:12px">Start with a free trial</h2>
      <p class="muted" style="margin-bottom:24px">30 days, all features, no credit card required. Contact us for volume pricing and government invoicing.</p>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap"><a href="/pricing" class="btn-secondary">View pricing</a><a href={site.hero.ctaPrimaryUrl} class="btn-primary">Start free trial</a></div>
    </div>
  </section>
  <style is:inline>
    .eyebrow{font-size:12px;font-weight:600;color:var(--brand);letter-spacing:0.06em;text-transform:uppercase;margin-bottom:12px}
    .usecase-hero{max-width:700px}
    .benefit-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px}
    .benefit{padding:24px;border:1px solid var(--border);border-radius:14px;background:#fff}
    .benefit h3{font-size:16px;font-weight:600;margin-bottom:8px}
    .benefit .muted{font-size:14px;line-height:1.7}
    @media(max-width:768px){.benefit-grid{grid-template-columns:1fr}}
  </style>
</BaseLayout>
