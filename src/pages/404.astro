---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page not found">
  <section class="section-pad">
    <div class="container text-center" style="max-width:500px;padding:80px 0">
      <h1 style="font-size:48px;font-weight:800;margin-bottom:12px">404</h1>
      <p class="muted" style="margin-bottom:24px">The page you are looking for does not exist or has been moved.</p>
      <a href="/" class="btn-primary">Back to homepage</a>
    </div>
  </section>
</BaseLayout>
