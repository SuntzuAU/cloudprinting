---
import BaseLayout from '../layouts/BaseLayout.astro';
import ACForm from '../components/ACForm.astro';
import site from '../site.config.json';
const c = site.colours;

const extraSchema = [{
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contact Cloud Printing Australia",
  "description": "Get in touch for Printix cloud print management enquiries, free trials, volume pricing, and support.",
  "url": site.siteUrl + "/contact",
  "isPartOf": { "@type": "WebSite", "name": site.siteName, "url": site.siteUrl }
}];
---
<BaseLayout title="Contact us -- Printix Cloud Print Management" description="Get in touch for Printix cloud print management enquiries, free trials, volume pricing, and support." extraSchema={extraSchema}>
  <section style="padding:80px 20px;background:#fff">
    <div style="max-width:900px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:start">
      <div>
        <h1 style="font-size:clamp(28px,4vw,42px);font-weight:800;margin-bottom:16px;color:#0f172a">Contact us</h1>
        <p style="color:#475569;font-size:16px;line-height:1.6;margin-bottom:24px">Questions about Printix cloud print management? Need a quote for your organisation? Want to start a free trial? Get in touch and our team will respond promptly.</p>
        <div style="margin-bottom:20px">
          <div style="font-weight:700;font-size:15px;color:#0f172a;margin-bottom:4px">Local Australian support</div>
          <div style="color:#64748B;font-size:14px">Voice Recognition Australia has 25 years of experience deploying enterprise technology across Australian business, government, healthcare and education.</div>
        </div>
        <div style="margin-bottom:20px">
          <div style="font-weight:700;font-size:15px;color:#0f172a;margin-bottom:4px">Free 30-day trial</div>
          <div style="color:#64748B;font-size:14px">All Printix features included. No credit card required. We can help you get started.</div>
        </div>
        <div>
          <div style="font-weight:700;font-size:15px;color:#0f172a;margin-bottom:4px">Volume and multi-year pricing</div>
          <div style="color:#64748B;font-size:14px">Discounts available for 300+ users and multi-year commitments. Education and non-profit pricing available.</div>
        </div>
      </div>
      <div style="background:#fff;border:1px solid #e2e8f0;border-radius:12px;padding:28px">
        <ACForm />
      </div>
    </div>
  </section>
  <style is:inline>
    @media (max-width: 768px) {
      .contact-grid { grid-template-columns: 1fr !important; }
    }
  </style>
  <script is:inline>
    // Fix grid class for responsive
    (function() {
      var grid = document.querySelector('[style*="grid-template-columns:1fr 1fr"]');
      if (grid) grid.classList.add('contact-grid');
    })();
  </script>
</BaseLayout>
